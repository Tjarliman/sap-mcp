# Copy this file to .env and fill in YOUR OWN values.
#   copy .env.example .env   (Windows)   |   cp .env.example .env   (macOS/Linux)
#
# Per profile: HOST, CLIENT, USER, PASS. server.js contains none of these, so
# real hostnames never end up in the repo. Get the real HOST/CLIENT for each
# system from your team; use your own named SAP user for USER/PASS.
# Never commit .env - it is gitignored on purpose.

# ABLD - Development
SAP_ABLD_HOST="https://sap-dev.example.com:44300"
SAP_ABLD_CLIENT="100"
SAP_ABLD_USER=""
SAP_ABLD_PASS=""

# dev120 - Development, client 120
SAP_DEV120_HOST="https://sap-dev.example.com:44300"
SAP_DEV120_CLIENT="120"
SAP_DEV120_USER=""
SAP_DEV120_PASS=""

# snet - QA/Test
SAP_SNET_HOST="https://sap-qa.example.com:44300"
SAP_SNET_CLIENT="100"
SAP_SNET_USER=""
SAP_SNET_PASS=""

# ABLP - Production (writes blocked in server.js; reads allowed)
SAP_ABLP_HOST="https://sap-prd.example.com:44300"
SAP_ABLP_CLIENT="500"
SAP_ABLP_USER=""
SAP_ABLP_PASS=""

# snet2 - S/4HANA on-prem
SAP_SNET2_HOST="http://sap-onprem.example.com:8000"
SAP_SNET2_CLIENT="100"
SAP_SNET2_USER=""
SAP_SNET2_PASS=""
